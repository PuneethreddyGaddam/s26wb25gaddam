doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title= title
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css", rel="stylesheet", integrity="sha384-sRI4k1xILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB", crossorigin="anonymous")
  body
    .container.py-5
      h1= title
    - let results = [{ camp_name: 'Prairie Sky Yurts', location: 'Flint Hills', capacity: 6 }, { camp_name: 'Canyon Echo Yurts', location: 'Red River Gorge', capacity: 4 }, { camp_name: 'Pine Ridge Yurts', location: 'Ozark Highlands', capacity: 8 }]
    .container-fluid
      .row.g-3
        each item in results
          .col-sm-2
            .p-2.border.rounded.bg-light
              strong #{item.camp_name}
              br
              span Location: #{item.location}
              br
              span Capacity: #{item.capacity}
