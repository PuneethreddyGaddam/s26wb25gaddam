doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title= title
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css", rel="stylesheet", integrity="sha384-sRI4k1xILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB", crossorigin="anonymous")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js", integrity="sha384-G/EV+4j2dNv+TEPo3++6LCgdCR0aejBqfUeNjuKAIuXbjrxilcCdDz6ZAVfHWe1Y", crossorigin="anonymous")
    style.
      .pill-btn {
        background: linear-gradient(180deg, #ffb55c 0%, #ff9a2e 50%, #ff7a00 100%);
        border: 4px solid #111318;
        color: #ffffff;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        border-radius: 999px;
        box-shadow: 0 8px 0 rgba(17, 19, 24, 0.95), 0 10px 18px rgba(17, 19, 24, 0.22);
        padding: 0.65rem 2.1rem;
        line-height: 1;
        transition: transform 120ms ease, box-shadow 120ms ease;
      }
      .pill-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 0 rgba(17, 19, 24, 0.95), 0 12px 20px rgba(17, 19, 24, 0.24);
      }
      .pill-btn:active {
        transform: translateY(1px);
        box-shadow: 0 4px 0 rgba(17, 19, 24, 0.95), 0 8px 16px rgba(17, 19, 24, 0.2);
      }
      .use-text {
        font-size: 1.05rem;
        color: #1f2937;
        background: #ffffff;
        display: inline-block;
        padding: 0.1rem 0.4rem;
      }
  body
    .container.py-5
      h1= title
