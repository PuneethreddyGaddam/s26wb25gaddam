doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title= title
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css", rel="stylesheet", integrity="sha384-sRI4k1xILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB", crossorigin="anonymous")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js", integrity="sha384-G/EV+4j2dNv+TEPo3++6LCgdCR0aejBqfUeNjuKAIuXbjrxilcCdDz6ZAVfHWe1Y", crossorigin="anonymous")
    style.
      .glass-btn {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
        border: 1px solid rgba(255, 255, 255, 0.6);
        color: #0f172a;
        backdrop-filter: blur(14px) saturate(160%);
        -webkit-backdrop-filter: blur(14px) saturate(160%);
        border-radius: 999px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.7);
        letter-spacing: 0.2px;
        transition: transform 120ms ease, box-shadow 120ms ease;
      }
      .glass-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.8);
      }
      .glass-btn:active {
        transform: translateY(0);
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.6);
      }
  body
    .container.py-4
      h1= title
      p This paragraph confirms the Pug edit, Bootstrap load, and button update from the instructions.
      button(type="button", class="btn glass-btn px-4 py-2") Sample Button
