doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title= title
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css", rel="stylesheet", integrity="sha384-sRI4k1xILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB", crossorigin="anonymous")
    style.
      .hero {
        background: radial-gradient(circle at top left, rgba(255, 200, 120, 0.28), transparent 50%),
                    radial-gradient(circle at top right, rgba(147, 197, 253, 0.25), transparent 55%);
        border-radius: 24px;
        padding: 2rem 2.5rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      }
      .image-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.25rem;
      }
      .image-card {
        background: #ffffff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.12);
        border: 1px solid rgba(148, 163, 184, 0.2);
      }
      .image-card img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
      }
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js", integrity="sha384-G/EV+4j2dNv+TEPo3++6LCgdCR0aejBqfUeNjuKAIuXbjrxilcCdDz6ZAVfHWe1Y", crossorigin="anonymous")
    style.
      .pill-btn {
        background: linear-gradient(180deg, #ffb55c 0%, #ff9a2e 50%, #ff7a00 100%);
        border: 4px solid #111318;
        color: #ffffff;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        border-radius: 999px;
        box-shadow: 0 8px 0 rgba(17, 19, 24, 0.95), 0 10px 18px rgba(17, 19, 24, 0.22);
        padding: 0.65rem 2.1rem;
        line-height: 1;
        transition: transform 120ms ease, box-shadow 120ms ease;
      }
      .pill-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 0 rgba(17, 19, 24, 0.95), 0 12px 20px rgba(17, 19, 24, 0.24);
      }
      .pill-btn:active {
        transform: translateY(1px);
        box-shadow: 0 4px 0 rgba(17, 19, 24, 0.95), 0 8px 16px rgba(17, 19, 24, 0.2);
      }
      .use-text {
        font-size: 1.05rem;
        color: #1f2937;
        background: #ffffff;
        display: inline-block;
        padding: 0.1rem 0.4rem;
      }
  body
    .container.py-5
      .hero.mb-4
        h1.mb-2= title
        p.text-secondary.mb-0 A curated, randomized selection of three yurt campsite images.
      - let image_names = ['yurt-1.png', 'yurt-2.png', 'yurt-3.png', 'yurt-4.png', 'yurt-5.png']
      .image-grid
        - for (let i = 0; i < 3; i++) {
          - let pick = Math.floor(Math.random() * 5)
          .image-card
            img(src=`/images/${image_names[pick]}` alt=`${image_names[pick]}`)
        - }
